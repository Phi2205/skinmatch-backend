generator client {
  provider        = "prisma-client-js"
  output          = "../src/generated/prisma"
  previewFeatures = ["fullTextSearch", "extendedIndexes"]
  engineType      = "library"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model categories {
  id        Int        @id @default(autoincrement())
  name      String     @unique @db.VarChar(100)
  slug      String     @unique @db.VarChar(100)
  is_active Boolean    @default(true)
  products  products[]
}

model concerns {
  id               Int                @id @default(autoincrement())
  name             String             @unique @db.VarChar(100)
  slug             String             @unique @db.VarChar(100)
  product_concerns product_concerns[]
  user_concerns    user_concerns[]
}

model ingredients {
  id                  Int                   @id @default(autoincrement())
  name                String                @unique @db.VarChar(100)
  slug                String                @unique @db.VarChar(100)
  product_ingredients product_ingredients[]
}

model order_items {
  id         Int       @id @default(autoincrement())
  order_id   Int?
  product_id Int?
  quantity   Int?
  price      Int?
  orders     orders?   @relation(fields: [order_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  products   products? @relation(fields: [product_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model orders {
  id          Int           @id @default(autoincrement())
  user_id     Int?
  total_price Int?
  status      String?       @db.VarChar(50)
  created_at  DateTime?     @default(now()) @db.Timestamp(6)
  order_items order_items[]
  users       users?        @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model product_concerns {
  product_id Int
  concern_id Int
  concerns   concerns @relation(fields: [concern_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  products   products @relation(fields: [product_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([product_id, concern_id])
}

model product_ingredients {
  product_id    Int
  ingredient_id Int
  ingredients   ingredients @relation(fields: [ingredient_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  products      products    @relation(fields: [product_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([product_id, ingredient_id])
}

model product_skin_types {
  product_id   Int
  skin_type_id Int
  products     products   @relation(fields: [product_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  skin_types   skin_types @relation(fields: [skin_type_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([product_id, skin_type_id])
}

model products {
  id                  Int                   @id @default(autoincrement())
  name                String                @db.VarChar(255)
  price               Int
  category_id         Int?
  description         String?
  image_url           String?               @db.VarChar(255)
  is_featured         Boolean               @default(false)
  is_active           Boolean               @default(true)
  summary             String?               @db.VarChar(255)
  created_at          DateTime?             @default(now()) @db.Timestamp(6)
  order_items         order_items[]
  product_concerns    product_concerns[]
  product_ingredients product_ingredients[]
  product_skin_types  product_skin_types[]
  product_badges      product_badges[]
  product_images      product_images[]
  categories          categories?           @relation(fields: [category_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  user_behaviors      user_behaviors[]

  @@index([category_id], map: "idx_product_category")
}

model product_images {
  id         Int      @id @default(autoincrement())
  product_id Int
  image_url  String   @db.VarChar(255)
  alt_text   String?  @db.VarChar(255)
  is_main    Boolean  @default(false)
  products   products @relation(fields: [product_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model banners {
  id          Int      @id @default(autoincrement())
  title       String   @db.VarChar(255)
  description String?
  image_url   String?  @db.VarChar(255)
  button_text String?  @db.VarChar(50)
  button_link String?  @db.VarChar(255)
  is_active   Boolean  @default(true)
  position    String   @default("HERO") @db.VarChar(50)
  created_at  DateTime @default(now()) @db.Timestamp(6)
}

model badges {
  id             Int              @id @default(autoincrement())
  name           String           @unique @db.VarChar(100)
  slug           String           @unique @db.VarChar(100)
  icon_url       String?          @db.VarChar(255)
  product_badges product_badges[]
}

model product_badges {
  product_id Int
  badge_id   Int
  badges     badges   @relation(fields: [badge_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  products   products @relation(fields: [product_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([product_id, badge_id])
}

model skin_profiles {
  id           Int         @id @default(autoincrement())
  user_id      Int?        @unique
  skin_type_id Int?
  sensitivity  String?     @db.VarChar(50)
  created_at   DateTime?   @default(now()) @db.Timestamp(6)
  users        users?      @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  skin_types   skin_types? @relation(fields: [skin_type_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model skin_types {
  id                 Int                  @id @default(autoincrement())
  name               String               @unique @db.VarChar(50)
  slug               String               @unique @db.VarChar(50)
  description        String?
  product_skin_types product_skin_types[]
  skin_profiles      skin_profiles[]
}

model user_behaviors {
  id         Int       @id @default(autoincrement())
  user_id    Int?
  product_id Int?
  action     String    @db.VarChar(50)
  created_at DateTime? @default(now()) @db.Timestamp(6)
  products   products? @relation(fields: [product_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users      users?    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([product_id], map: "idx_user_behavior_product")
  @@index([user_id], map: "idx_user_behavior_user")
}

model user_concerns {
  user_id    Int
  concern_id Int
  concerns   concerns @relation(fields: [concern_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users      users    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([user_id, concern_id])
}

model users {
  id             Int              @id @default(autoincrement())
  email          String           @unique @db.VarChar(255)
  password_hash  String?          @db.VarChar(255)
  name           String?          @db.VarChar(255)
  created_at     DateTime?        @default(now()) @db.Timestamp(6)
  role           Role             @default(USER)
  is_verified    Boolean          @default(false)
  orders         orders[]
  skin_profiles  skin_profiles?
  user_behaviors user_behaviors[]
  user_concerns  user_concerns[]
}

enum Role {
  ADMIN
  USER
}
